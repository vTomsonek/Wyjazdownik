APP_ENV=dev
APP_NAME="Wyjazdownik"
APP_URL=http://localhost/wyjazdownik/public
APP_TIMEZONE=Europe/Warsaw

# ----------------------------------------------------------------------------
# Baza danych
# ----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=wyjazdownik
DB_USER=root
DB_PASS=

# ----------------------------------------------------------------------------
# Mailer
# ----------------------------------------------------------------------------
# DRIVER:
#   log  = dev mode - mail trafia do storage/sent_emails.log + magic link na ekranie
#   smtp = production - PHPMailer wysyla przez podany serwer SMTP
MAIL_DRIVER=log
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@wyjazdownik.pl
MAIL_FROM_NAME="Wyjazdownik"

# Email do kontaktu w stopce (mailto link). Zwykle inna skrzynka niz noreply.
CONTACT_EMAIL=admin@wyjazdownik.pl

# Przyklady konfiguracji SMTP (odkomentuj jeden zestaw na produkcji):
#
# --- Postfix lokalny na Twoim VPS ---
# MAIL_DRIVER=smtp
# MAIL_HOST=localhost
# MAIL_PORT=25
# MAIL_USERNAME=
# MAIL_PASSWORD=
#
# --- Brevo (Sendinblue) - 300 maili dziennie free ---
# MAIL_DRIVER=smtp
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=twoj-login@smtp-brevo.com
# MAIL_PASSWORD=twoj_smtp_key_z_panelu_brevo
#
# --- Postmark - 100 maili miesiecznie free ---
# MAIL_DRIVER=smtp
# MAIL_HOST=smtp.postmarkapp.com
# MAIL_PORT=587
# MAIL_USERNAME=twoj_server_token
# MAIL_PASSWORD=twoj_server_token
#
# --- Resend - 100 maili dziennie free ---
# MAIL_DRIVER=smtp
# MAIL_HOST=smtp.resend.com
# MAIL_PORT=587
# MAIL_USERNAME=resend
# MAIL_PASSWORD=re_xxxxxxxxxxxxxxxx
#
# --- OVH SMTP (jesli masz mailbox u OVH) ---
# MAIL_DRIVER=smtp
# MAIL_HOST=ssl0.ovh.net
# MAIL_PORT=587
# MAIL_USERNAME=noreply@wyjazdownik.pl
# MAIL_PASSWORD=haslo_ze_skrzynki
#
# --- Gmail (TYLKO dla testow lokalnych - wymaga "App Password") ---
# MAIL_DRIVER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=twojemail@gmail.com
# MAIL_PASSWORD=app_password_16_znakow

# ----------------------------------------------------------------------------
# Pierwsze konto admina (uzywane przez install.php przy seed)
# ----------------------------------------------------------------------------
ADMIN_INITIAL_EMAIL=admin@example.com
ADMIN_INITIAL_NAME="Admin"

# ----------------------------------------------------------------------------
# Bezpieczenstwo / limity
# ----------------------------------------------------------------------------
UPLOAD_MAX_SIZE=2097152
SESSION_LIFETIME_HOURS=24
MAGIC_LINK_LIFETIME_MINUTES=15
